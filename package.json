{
  "name": "heyday",
  "version": "1.0.0",
  "description": "HEYDAY — real estate operations platform",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"nodemon server/index.js\" \"npm run dev --prefix client\"",
    "build": "npm run build --prefix client",
    "start": "NODE_ENV=production node server/index.js",
    "import-crm": "node server/scripts/import-fub-contacts.js",
    "sync-crm-fub": "node server/scripts/sync-fub-contacts-api.js",
    "import-brokermint": "node server/scripts/import-brokermint-transactions.js",
    "fix-brokermint-agents": "node server/scripts/fix-brokermint-agent-ids.js",
    "post-brokermint-import": "node server/scripts/post-brokermint-import.js",
    "clear-transactions": "node server/scripts/clear-transactions.js",
    "seed-sample-transactions": "node server/scripts/reset-transactions.js"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^11.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "googleapis": "^173.0.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.9"
  }
}
